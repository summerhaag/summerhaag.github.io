---
import variants from '../../data/parameter-space-variants.json';

const firstBuilt = variants.find(v => v.built)!;
const firstSrc = `/demos/${firstBuilt.id}/index.html`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ACP Parameter Space — Summer Haag</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #1e0a3c;
      --sidebar-bg:   #130520;
      --accent:       #c026d3;
      --accent-dim:   rgba(192, 38, 211, 0.2);
      --accent-border:rgba(192, 38, 211, 0.35);
      --text:         #ffffff;
      --text-muted:   #c4b5fd;
      --text-faint:   rgba(196, 181, 253, 0.45);
      --divider:      rgba(255, 255, 255, 0.08);
      --sidebar-w:    220px;
      --font:         'Inter', sans-serif;
    }

    html, body {
      width: 100%; height: 100%;
      background: var(--bg);
      font-family: var(--font);
      overflow: hidden;
    }

    /* ── Layout ── */
    .layout {
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      height: 100vh;
    }

    /* ── Sidebar ── */
    .sidebar {
      background: var(--sidebar-bg);
      border-right: 1px solid var(--accent-border);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--accent-dim) transparent;
    }

    .sidebar-top {
      padding: 1rem;
      border-bottom: 1px solid var(--divider);
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--text-faint);
      text-decoration: none;
      font-size: 0.75rem;
      font-weight: 500;
      margin-bottom: 0.85rem;
      transition: color 0.15s;
    }
    .back-link:hover { color: var(--text-muted); }

    .sidebar-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
    }

    .variant-list {
      padding: 0.75rem 0;
      flex: 1;
    }

    .variant-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.6rem 1rem;
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--text-muted);
      cursor: pointer;
      border-left: 2px solid transparent;
      transition: color 0.15s, background 0.15s, border-color 0.15s;
      user-select: none;
    }
    .variant-item:hover {
      color: var(--text);
      background: rgba(255,255,255,0.04);
    }
    .variant-item.active {
      color: var(--accent);
      border-left-color: var(--accent);
      background: var(--accent-dim);
    }

    .variant-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: currentColor;
      flex-shrink: 0;
      opacity: 0.6;
    }
    .variant-item.active .variant-dot { opacity: 1; }

    /* ── Viewer ── */
    .viewer {
      position: relative;
      overflow: hidden;
    }

    .viewer iframe {
      width: 100%; height: 100%;
      border: none;
      display: block;
    }
  </style>
</head>
<body>

  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-top">
        <a href="/#gallery" class="back-link">← Back</a>
        <div class="sidebar-title">ACP Parameter Space</div>
      </div>

      <nav class="variant-list">
        {variants.filter(v => v.built).map((v) => (
          <div
            class={`variant-item${v.id === firstBuilt.id ? ' active' : ''}`}
            data-src={`/demos/${v.id}/index.html`}
          >
            <span class="variant-dot"></span>
            {v.title}
          </div>
        ))}
      </nav>
    </aside>

    <div class="viewer">
      <iframe id="viewer-frame" src={firstSrc} title="ACP Parameter Space" allow="pointer-lock"></iframe>
    </div>
  </div>

  <script>
    const frame = document.getElementById('viewer-frame') as HTMLIFrameElement;

    document.querySelectorAll<HTMLElement>('.variant-item:not([data-disabled])').forEach(item => {
      item.addEventListener('click', () => {
        document.querySelectorAll('.variant-item').forEach(i => i.classList.remove('active'));
        item.classList.add('active');
        frame.src = item.dataset.src!;
      });
    });
  </script>

</body>
</html>
